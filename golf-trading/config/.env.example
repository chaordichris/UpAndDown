# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# --- DataGolf ---
DATAGOLF_API_KEY=your_key_here

# --- Database ---
# Defaults to SQLite. Override for PostgreSQL:
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/golf_trading
DATABASE_URL=sqlite:///./data/db/golf_trading.db

# --- Environment ---
# "development" or "production"
APP_ENV=development

# --- Logging ---
LOG_LEVEL=INFO
